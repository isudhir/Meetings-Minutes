# Provider for BOTH transcription and generation: openai (default) or openrouter
LLM_PROVIDER=openai

# OpenAI key — required when LLM_PROVIDER=openai
OPENAI_API_KEY=

# OpenRouter key — required when LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=

GENERATION_MODEL=gpt-4o-mini


TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# Max upload size in MB (OpenAI's hard limit is 25)
MAX_UPLOAD_MB=25

CHAT_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Upload rate limit, per client IP + browser. Set the window to 0 to disable.
RATE_LIMIT_UPLOADS=1
RATE_LIMIT_WINDOW_SECONDS=600
