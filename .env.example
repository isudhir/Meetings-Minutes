# Provider for BOTH transcription and generation: openai (default) or openrouter
LLM_PROVIDER=openai

# OpenAI key — required when LLM_PROVIDER=openai
OPENAI_API_KEY=

# OpenRouter key — required when LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=

# Chat model that writes the minutes
# openai example:     gpt-4o-mini
# openrouter example: openai/gpt-4o-mini  or  meta-llama/llama-3.3-70b-instruct
GENERATION_MODEL=gpt-4o-mini

# Audio transcription model (must match the selected provider)
# openai example:     gpt-4o-mini-transcribe  or  whisper-1
# openrouter example: openai/whisper-1  or  openai/whisper-large-v3
TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# Max upload size in MB (OpenAI's hard limit is 25)
MAX_UPLOAD_MB=25
